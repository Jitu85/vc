# Backend
NODE_ENV=development
API_PORT=8787
DATABASE_URL=postgresql://virtual_classroom_app:replace-me@127.0.0.1:5432/virtual_classroom
DATABASE_SSL=false
DATABASE_SSL_REJECT_UNAUTHORIZED=true
DATABASE_POOL_MAX=10
CORS_ORIGINS=http://127.0.0.1:4173,http://localhost:4173,http://127.0.0.1:5173,http://localhost:5173
AUTH_OTP_PEPPER=replace-with-at-least-32-random-characters
SESSION_TTL_DAYS=7
OTP_TTL_MINUTES=10

# Use console only for local development. Production requires smtp.
EMAIL_MODE=console
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=replace-me
SMTP_PASSWORD=replace-me
SMTP_FROM=Virtual Classroom <no-reply@example.com>

# Frontend (Vite exposes only variables prefixed with VITE_)
VITE_API_BASE_URL=http://127.0.0.1:8787/api/v1
