{
  "name": "virtual-classroom-grammar",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "dev:web": "vite",
    "dev:api": "tsx watch server/src/index.ts",
    "build": "npm run check && vite build && npm run build:api",
    "build:api": "tsc -p server/tsconfig.json",
    "preview": "vite preview",
    "start:api": "node server/dist/index.js",
    "check": "tsc --noEmit && tsc -p server/tsconfig.json --noEmit",
    "db:migrate": "tsx server/scripts/migrate.ts",
    "admin:create": "tsx server/src/create-admin.ts",
    "test": "npm run test:web && npm run test:api",
    "test:web": "node --test --test-isolation=none tests/*.test.mjs",
    "test:api": "node --import tsx --test --test-isolation=none server/tests/*.test.ts"
  },
  "dependencies": {
    "argon2": "^0.44.0",
    "cookie": "^2.0.1",
    "cors": "^2.8.6",
    "dotenv": "^17.4.2",
    "express": "^5.2.1",
    "helmet": "^8.2.0",
    "nodemailer": "^9.0.3",
    "pg": "^8.22.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/nodemailer": "^8.0.1",
    "@types/pg": "^8.20.0",
    "@types/react": "^19.0.00",
    "@types/react-dom": "^19.0.3",
    "@vitejs/plugin-react": "^4.3.4",
    "playwright": "^1.61.1",
    "tsx": "^4.23.0",
    "typescript": "^5.7.2",
    "vite": "^6.1.0"
  }
}
